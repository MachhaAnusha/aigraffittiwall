REPLICATE_API_TOKEN=
PERSPECTIVE_API_KEY=
GOOGLE_CLOUD_VISION_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ADMIN_PASSWORD=changeme
PORT=3001
VITE_SOCKET_URL=http://localhost:3001

# Rate limiting (submissions per device per window)
# Set to 0 to disable — default is 0 in dev, 3 in production
RATE_LIMIT_MAX=0
RATE_LIMIT_WINDOW_MS=300000

# Skip admin approval queue (default ON in dev, OFF in production)
AUTO_APPROVE=true

# Force demo mode: show canvas on wall without AI (auto ON when REPLICATE_API_TOKEN is missing in dev)
DEMO_MODE=true
